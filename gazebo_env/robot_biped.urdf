<?xml version="1.0"?>
<robot name="humanoid_biped">

<!-- ========================================== -->
<!-- 躯干 base_link -->
<!-- ========================================== -->
<link name="base_link">
  <inertial>
    <mass value="8.0"/>
    <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
  </inertial>
  <visual>
    <geometry>
      <box size="0.3 0.25 0.55"/>
    </geometry>
  </visual>
  <collision>
    <geometry>
      <box size="0.3 0.25 0.55"/>
    </geometry>
  </collision>
</link>

<gazebo reference="base_link">
  <material>Gazebo/DarkBlue</material>
</gazebo>

<!-- ========================================== -->
<!-- 头部 head_link -->
<!-- ========================================== -->
<link name="head_link">
  <inertial>
    <mass value="1.2"/>
    <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/>
  </inertial>
  <visual>
    <geometry>
      <sphere radius="0.12"/>
    </geometry>
  </visual>
  <collision>
    <geometry>
      <sphere radius="0.12"/>
    </geometry>
  </collision>
</link>

<joint name="head_joint" type="fixed">
  <parent link="base_link"/>
  <child link="head_link"/>
  <origin xyz="0 0 0.4" rpy="0 0 0"/>
</joint>

<gazebo reference="head_link">
  <material>Gazebo/Orange</material>
</gazebo>

<!-- ========================================== -->
<!-- 双目相机：left_camera + right_camera -->
<!-- ========================================== -->
<link name="left_camera_link">
  <inertial>
    <mass value="0.08"/>
    <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
  </inertial>
  <visual>
    <geometry>
      <box size="0.05 0.05 0.05"/>
    </geometry>
  </visual>
</link>

<link name="right_camera_link">
  <inertial>
    <mass value="0.08"/>
    <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
  </inertial>
  <visual>
    <geometry>
      <box size="0.05 0.05 0.05"/>
    </geometry>
  </visual>
</link>

<joint name="left_camera_joint" type="fixed">
  <parent link="head_link"/>
  <child link="left_camera_link"/>
  <origin xyz="0.04 0.08 0" rpy="0 0 0"/>
</joint>

<joint name="right_camera_joint" type="fixed">
  <parent link="head_link"/>
  <child link="right_camera_link"/>
  <origin xyz="0.04 -0.08 0" rpy="0 0 0"/>
</joint>

<gazebo reference="left_camera_link">
  <material>Gazebo/Red</material>
</gazebo>
<gazebo reference="right_camera_link">
  <material>Gazebo/Red</material>
</gazebo>

<!-- 左目相机插件 -->
<gazebo reference="left_camera_link">
  <sensor name="left_camera" type="camera">
    <always_on>true</always_on>
    <update_rate>30</update_rate>
    <camera>
      <width>640</width>
      <height>480</height>
      <hfov>60</hfov>
    </camera>
    <plugin name="left_camera_plugin" filename="libgazebo_ros_camera.so">
      <ros>
        <namespace>/left_camera</namespace>
      </ros>
    </plugin>
  </sensor>
</gazebo>

<!-- 右目相机插件 -->
<gazebo reference="right_camera_link">
  <sensor name="right_camera" type="camera">
    <always_on>true</always_on>
    <update_rate>30</update_rate>
    <camera>
      <width>640</width>
      <height>480</height>
      <hfov>60</hfov>
    </camera>
    <plugin name="right_camera_plugin" filename="libgazebo_ros_camera.so">
      <ros>
        <namespace>/right_camera</namespace>
      </ros>
    </plugin>
  </sensor>
</gazebo>

<!-- ========================================== -->
<!-- 左腿 left_leg_link -->
<!-- ========================================== -->
<link name="left_leg_link">
  <inertial>
    <mass value="3.0"/>
    <inertia ixx="0.2" ixy="0" ixz="0" iyy="0.2" iyz="0" izz="0.2"/>
  </inertial>
  <visual>
    <geometry>
      <cylinder radius="0.08" length="0.45"/>
    </geometry>
  </visual>
  <collision>
    <geometry>
      <cylinder radius="0.08" length="0.45"/>
    </geometry>
  </collision>
</link>

<joint name="left_leg_joint" type="fixed">
  <parent link="base_link"/>
  <child link="left_leg_link"/>
  <origin xyz="0 0.12 -0.35" rpy="0 0 0"/>
</joint>

<gazebo reference="left_leg_link">
  <material>Gazebo/Gray</material>
</gazebo>

<!-- ========================================== -->
<!-- 右腿 right_leg_link -->
<!-- ========================================== -->
<link name="right_leg_link">
  <inertial>
    <mass value="3.0"/>
    <inertia ixx="0.2" ixy="0" ixz="0" iyy="0.2" iyz="0" izz="0.2"/>
  </inertial>
  <visual>
    <geometry>
      <cylinder radius="0.08" length="0.45"/>
    </geometry>
  </visual>
  <collision>
    <geometry>
      <cylinder radius="0.08" length="0.45"/>
    </geometry>
  </collision>
</link>

<joint name="right_leg_joint" type="fixed">
  <parent link="base_link"/>
  <child link="right_leg_link"/>
  <origin xyz="0 -0.12 -0.35" rpy="0 0 0"/>
</joint>

<gazebo reference="right_leg_link">
  <material>Gazebo/Gray</material>
</gazebo>

</robot>
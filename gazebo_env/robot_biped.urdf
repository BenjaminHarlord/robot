<?xml version="1.0"?>
<robot name="humanoid_biped">

<!-- ========================================== -->
<!-- 躯干 base_link -->
<!-- ========================================== -->
<link name="base_link">
  <inertial>
    <mass value="8.0"/>
    <inertia ixx="0.3" ixy="0.0" ixz="0.0" iyy="0.4" iyz="0.0" izz="0.2"/>
  </inertial>
  <visual>
    <geometry>
      <box size="0.3 0.25 0.55"/>
    </geometry>
  </visual>
  <collision>
    <geometry>
      <box size="0.3 0.25 0.55"/>
    </geometry>
  </collision>
</link>

<gazebo reference="base_link">
  <material>Gazebo/DarkBlue</material>
  <mu1 value="0.2"/>
  <mu2 value="0.2"/>
  <kp value="1000000.0"/>
  <kd value="100.0"/>
</gazebo>

<!-- ========================================== -->
<!-- 左臂 left_arm_link -->
<!-- ========================================== -->
<link name="left_arm_link">
  <inertial>
    <mass value="1.0"/>
    <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.05"/>
    <origin xyz="0 0 -0.1"/>
  </inertial>
  <visual>
    <geometry>
      <cylinder radius="0.05" length="0.2"/>
    </geometry>
    <origin xyz="0 0 -0.1"/>
  </visual>
  <collision>
    <geometry>
      <cylinder radius="0.05" length="0.2"/>
    </geometry>
    <origin xyz="0 0 -0.1"/>
  </collision>
</link>

<joint name="left_shoulder_joint" type="revolute">
  <parent link="base_link"/>
  <child link="left_arm_link"/>
  <origin xyz="0.1 0.15 0.1" rpy="0 0 0"/>
  <axis xyz="0 0 1"/>
  <limit lower="-1.57" upper="1.57" effort="50" velocity="2.0"/>
  <dynamics damping="2.0" friction="1.0"/>
</joint>

<!-- ========================================== -->
<!-- 右臂 right_arm_link -->
<!-- ========================================== -->
<link name="right_arm_link">
  <inertial>
    <mass value="1.0"/>
    <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.05"/>
    <origin xyz="0 0 -0.1"/>
  </inertial>
  <visual>
    <geometry>
      <cylinder radius="0.05" length="0.2"/>
    </geometry>
    <origin xyz="0 0 -0.1"/>
  </visual>
  <collision>
    <geometry>
      <cylinder radius="0.05" length="0.2"/>
    </geometry>
    <origin xyz="0 0 -0.1"/>
  </collision>
</link>

<joint name="right_shoulder_joint" type="revolute">
  <parent link="base_link"/>
  <child link="right_arm_link"/>
  <origin xyz="0.1 -0.15 0.1" rpy="0 0 0"/>
  <axis xyz="0 0 1"/>
  <limit lower="-1.57" upper="1.57" effort="50" velocity="2.0"/>
  <dynamics damping="2.0" friction="1.0"/>
</joint>

<gazebo reference="left_arm_link">
  <material>Gazebo/Green</material>
</gazebo>

<gazebo reference="right_arm_link">
  <material>Gazebo/Green</material>
</gazebo>

<!-- ========================================== -->
<!-- 头部 head_link -->
<!-- ========================================== -->
<link name="head_link">
  <inertial>
    <mass value="1.2"/>
    <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/>
    <origin xyz="0 0 0"/>
  </inertial>
  <visual>
    <geometry>
      <sphere radius="0.12"/>
    </geometry>
    <origin xyz="0 0 0"/>
  </visual>
  <collision>
    <geometry>
      <sphere radius="0.12"/>
    </geometry>
    <origin xyz="0 0 0"/>
  </collision>
</link>

<joint name="head_joint" type="revolute">
  <parent link="base_link"/>
  <child link="head_link"/>
  <origin xyz="0 0 0.275" rpy="0 0 0"/>
  <axis xyz="0 1 0"/>
  <limit lower="-0.5" upper="0.5" effort="20" velocity="1.0"/>
  <dynamics damping="1.0" friction="0.5"/>
</joint>

<gazebo reference="head_link">
  <material>Gazebo/Orange</material>
  <mu1 value="0.2"/>
  <mu2 value="0.2"/>
</gazebo>

<!-- ========================================== -->
<!-- 双目相机：left_camera + right_camera -->
<!-- ========================================== -->
<link name="left_camera_link">
  <inertial>
    <mass value="0.01"/>
    <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    <origin xyz="0 0 0"/>
  </inertial>
  <visual>
    <geometry>
      <box size="0.02 0.02 0.02"/>
    </geometry>
    <origin xyz="0 0 0"/>
  </visual>
  <collision>
    <geometry>
      <box size="0.02 0.02 0.02"/>
    </geometry>
    <origin xyz="0 0 0"/>
  </collision>
</link>

<link name="right_camera_link">
  <inertial>
    <mass value="0.01"/>
    <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    <origin xyz="0 0 0"/>
  </inertial>
  <visual>
    <geometry>
      <box size="0.02 0.02 0.02"/>
    </geometry>
    <origin xyz="0 0 0"/>
  </visual>
  <collision>
    <geometry>
      <box size="0.02 0.02 0.02"/>
    </geometry>
    <origin xyz="0 0 0"/>
  </collision>
</link>

<joint name="left_camera_joint" type="fixed">
  <parent link="head_link"/>
  <child link="left_camera_link"/>
  <origin xyz="0.06 0.08 0" rpy="0 0 0"/>
</joint>

<joint name="right_camera_joint" type="fixed">
  <parent link="head_link"/>
  <child link="right_camera_link"/>
  <origin xyz="0.06 -0.08 0" rpy="0 0 0"/>
</joint>

<gazebo reference="left_camera_link">
  <material>Gazebo/Red</material>
  <mu1 value="0.1"/>
  <mu2 value="0.1"/>
</gazebo>
<gazebo reference="right_camera_link">
  <material>Gazebo/Red</material>
  <mu1 value="0.1"/>
  <mu2 value="0.1"/>
</gazebo>

<!-- 左目相机插件 -->
<gazebo reference="left_camera_link">
  <sensor name="left_camera" type="camera">
    <always_on>true</always_on>
    <update_rate>30</update_rate>
    <camera>
      <width>640</width>
      <height>480</height>
      <hfov>60</hfov>
    </camera>
    <plugin name="left_camera_plugin" filename="libgazebo_ros_camera.so">
      <ros>
        <namespace>/left_camera</namespace>
      </ros>
    </plugin>
  </sensor>
</gazebo>

<!-- 右目相机插件 -->
<gazebo reference="right_camera_link">
  <sensor name="right_camera" type="camera">
    <always_on>true</always_on>
    <update_rate>30</update_rate>
    <camera>
      <width>640</width>
      <height>480</height>
      <hfov>60</hfov>
    </camera>
    <plugin name="right_camera_plugin" filename="libgazebo_ros_camera.so">
      <ros>
        <namespace>/right_camera</namespace>
      </ros>
    </plugin>
  </sensor>
</gazebo>

<!-- ========================================== -->
<!-- 左大腿 left_thigh_link -->
<!-- ========================================== -->
<link name="left_thigh_link">
  <inertial>
    <mass value="1.5"/>
    <inertia ixx="0.02" ixy="0.0" ixz="0.0" iyy="0.02" iyz="0.0" izz="0.1"/>
    <origin xyz="0 0 -0.1125"/>
  </inertial>
  <visual>
    <geometry>
      <cylinder radius="0.08" length="0.225"/>
    </geometry>
    <origin xyz="0 0 -0.1125"/>
  </visual>
  <collision>
    <geometry>
      <cylinder radius="0.08" length="0.225"/>
    </geometry>
    <origin xyz="0 0 -0.1125"/>
  </collision>
</link>

<joint name="left_hip_joint" type="revolute">
  <parent link="base_link"/>
  <child link="left_thigh_link"/>
  <origin xyz="0 0.12 -0.275" rpy="0 0 0"/>
  <axis xyz="0 0 1"/>
  <limit lower="-1.57" upper="1.57" effort="100" velocity="3.0"/>
  <dynamics damping="5.0" friction="1.0"/>
</joint>

<!-- ========================================== -->
<!-- 左小腿 left_shin_link -->
<!-- ========================================== -->
<link name="left_shin_link">
  <inertial>
    <mass value="1.5"/>
    <inertia ixx="0.02" ixy="0.0" ixz="0.0" iyy="0.02" iyz="0.0" izz="0.1"/>
    <origin xyz="0 0 -0.1125"/>
  </inertial>
  <visual>
    <geometry>
      <cylinder radius="0.08" length="0.225"/>
    </geometry>
    <origin xyz="0 0 -0.1125"/>
  </visual>
  <collision>
    <geometry>
      <cylinder radius="0.08" length="0.225"/>
    </geometry>
    <origin xyz="0 0 -0.1125"/>
  </collision>
</link>

<joint name="left_knee_joint" type="revolute">
  <parent link="left_thigh_link"/>
  <child link="left_shin_link"/>
  <origin xyz="0 0 -0.225" rpy="0 0 0"/>
  <axis xyz="0 0 1"/>
  <limit lower="0" upper="1.57" effort="100" velocity="3.0"/>
  <dynamics damping="3.0" friction="1.0"/>
</joint>

<!-- ========================================== -->
<!-- 左脚 left_foot_link -->
<!-- ========================================== -->
<link name="left_foot_link">
  <inertial>
    <mass value="0.8"/>
    <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.02" iyz="0.0" izz="0.02"/>
    <origin xyz="0.05 0 0"/>
  </inertial>
  <visual>
    <geometry>
      <box size="0.15 0.1 0.05"/>
    </geometry>
    <origin xyz="0.05 0 0"/>
  </visual>
  <collision>
    <geometry>
      <box size="0.15 0.1 0.05"/>
    </geometry>
    <origin xyz="0.05 0 0"/>
  </collision>
</link>

<joint name="left_ankle_joint" type="revolute">
  <parent link="left_shin_link"/>
  <child link="left_foot_link"/>
  <origin xyz="0 0 -0.225" rpy="0 0 0"/>
  <axis xyz="0 1 0"/>
  <limit lower="-0.5" upper="0.5" effort="50" velocity="2.0"/>
  <dynamics damping="2.0" friction="1.0"/>
</joint>

<gazebo reference="left_thigh_link">
  <material>Gazebo/Gray</material>
</gazebo>

<gazebo reference="left_shin_link">
  <material>Gazebo/Gray</material>
</gazebo>

<gazebo reference="left_foot_link">
  <material>Gazebo/White</material>
  <mu1 value="1.0"/>
  <mu2 value="1.0"/>
  <kp value="1000000.0"/>
  <kd value="100.0"/>
</gazebo>

<!-- ========================================== -->
<!-- 右大腿 right_thigh_link -->
<!-- ========================================== -->
<link name="right_thigh_link">
  <inertial>
    <mass value="1.5"/>
    <inertia ixx="0.02" ixy="0.0" ixz="0.0" iyy="0.02" iyz="0.0" izz="0.1"/>
    <origin xyz="0 0 -0.1125"/>
  </inertial>
  <visual>
    <geometry>
      <cylinder radius="0.08" length="0.225"/>
    </geometry>
    <origin xyz="0 0 -0.1125"/>
  </visual>
  <collision>
    <geometry>
      <cylinder radius="0.08" length="0.225"/>
    </geometry>
    <origin xyz="0 0 -0.1125"/>
  </collision>
</link>

<joint name="right_hip_joint" type="revolute">
  <parent link="base_link"/>
  <child link="right_thigh_link"/>
  <origin xyz="0 -0.12 -0.275" rpy="0 0 0"/>
  <axis xyz="0 0 1"/>
  <limit lower="-1.57" upper="1.57" effort="100" velocity="3.0"/>
  <dynamics damping="5.0" friction="1.0"/>
</joint>

<!-- ========================================== -->
<!-- 右小腿 right_shin_link -->
<!-- ========================================== -->
<link name="right_shin_link">
  <inertial>
    <mass value="1.5"/>
    <inertia ixx="0.02" ixy="0.0" ixz="0.0" iyy="0.02" iyz="0.0" izz="0.1"/>
    <origin xyz="0 0 -0.1125"/>
  </inertial>
  <visual>
    <geometry>
      <cylinder radius="0.08" length="0.225"/>
    </geometry>
    <origin xyz="0 0 -0.1125"/>
  </visual>
  <collision>
    <geometry>
      <cylinder radius="0.08" length="0.225"/>
    </geometry>
    <origin xyz="0 0 -0.1125"/>
  </collision>
</link>

<joint name="right_knee_joint" type="revolute">
  <parent link="right_thigh_link"/>
  <child link="right_shin_link"/>
  <origin xyz="0 0 -0.225" rpy="0 0 0"/>
  <axis xyz="0 0 1"/>
  <limit lower="0" upper="1.57" effort="100" velocity="3.0"/>
  <dynamics damping="3.0" friction="1.0"/>
</joint>

<!-- ========================================== -->
<!-- 右脚 right_foot_link -->
<!-- ========================================== -->
<link name="right_foot_link">
  <inertial>
    <mass value="0.8"/>
    <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.02" iyz="0.0" izz="0.02"/>
    <origin xyz="0.05 0 0"/>
  </inertial>
  <visual>
    <geometry>
      <box size="0.15 0.1 0.05"/>
    </geometry>
    <origin xyz="0.05 0 0"/>
  </visual>
  <collision>
    <geometry>
      <box size="0.15 0.1 0.05"/>
    </geometry>
    <origin xyz="0.05 0 0"/>
  </collision>
</link>

<joint name="right_ankle_joint" type="revolute">
  <parent link="right_shin_link"/>
  <child link="right_foot_link"/>
  <origin xyz="0 0 -0.225" rpy="0 0 0"/>
  <axis xyz="0 1 0"/>
  <limit lower="-0.5" upper="0.5" effort="50" velocity="2.0"/>
  <dynamics damping="2.0" friction="1.0"/>
</joint>

<gazebo reference="right_thigh_link">
  <material>Gazebo/Gray</material>
</gazebo>

<gazebo reference="right_shin_link">
  <material>Gazebo/Gray</material>
</gazebo>

<gazebo reference="right_foot_link">
  <material>Gazebo/White</material>
  <mu1 value="1.0"/>
  <mu2 value="1.0"/>
  <kp value="1000000.0"/>
  <kd value="100.0"/>
</gazebo>

</robot>